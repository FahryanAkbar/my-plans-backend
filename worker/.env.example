NODE_ENV=production

# Queue / Redis
QUEUE_NAME=monitoring-queue
REDIS_HOST=redis
REDIS_PORT=6379

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=replace_with_secure_influx_token
INFLUXDB_ORG=my-plans
INFLUXDB_BUCKET=monitoring

# Worker runtime
WORKER_CONCURRENCY=5
DEFAULT_TIMEOUT_MS=30000
DEFAULT_EXPECTED_STATUS=200
HEARTBEAT_INTERVAL_MS=10000
HEARTBEAT_TTL_SECONDS=15

# Optional: set this only when using a system-installed Chrome/Chromium.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
